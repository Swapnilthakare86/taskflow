# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=taskflow_db
DB_CONNECTION_LIMIT=10

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=mysecretkey
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Bcrypt ───────────────────────────────────────────────────
BCRYPT_ROUNDS=12

ALLOWED_EMAIL_DOMAINS=xtsworld.in,gmail.com

# Email / Zoho SMTP
# Use a Zoho app password here, not your normal mailbox password.
SMTP_HOST=smtp.zoho.in
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@xtsworld.in
SMTP_PASS=your-zoho-app-password
SMTP_FROM_NAME=TaskFlow
SMTP_FROM_EMAIL=your-email@xtsworld.in
